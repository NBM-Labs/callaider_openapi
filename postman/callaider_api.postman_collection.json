              "raw": "{{base_url}}/ringing/subscriber-groups/{{subscriber_group_id}}",
              "host": ["{{base_url}}"],
              "path": ["ringing", "subscriber-groups", "{{subscriber_group_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Прозвон — Абоненти",
      "item": [
        {
          "name": "Завантажити пакет (batch)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
