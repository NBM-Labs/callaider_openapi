              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subscriberGroupId\": {{subscriber_group_id}},\n  \"phones\": [\n    \"+380501234567\",\n    \"+380671234567\"\n  ],\n  \"extraData\": [\n    {\"name\": \"Іван\", \"orderId\": \"001\"},\n    {\"name\": \"Олена\", \"orderId\": \"002\"}\n  ],\n  \"onlyUniquePhones\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/ringing/subscribers/batch",
              "host": ["{{base_url}}"],
              "path": ["ringing", "subscribers", "batch"]
            }
          }
        },
        {
          "name": "Список абонентів групи",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/ringing/subscribers?groupId={{subscriber_group_id}}",
              "host": ["{{base_url}}"],
              "path": ["ringing", "subscribers"],
              "query": [
                {
                  "key": "groupId",
                  "value": "{{subscriber_group_id}}"
                }
              ]
            }
          }
        },
        {
          "name": "Видалити абонента",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/ringing/subscribers/1",
              "host": ["{{base_url}}"],
              "path": ["ringing", "subscribers", "1"]
            }
          }
        }
      ]
    },
